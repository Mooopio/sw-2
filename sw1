<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clean Code – Ultimate Exam Cheat Sheet</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --card: #16161f;
    --border: #1e1e2e;
    --accent1: #7c3aed;
    --accent2: #06b6d4;
    --accent3: #f59e0b;
    --accent4: #10b981;
    --accent5: #ef4444;
    --accent6: #ec4899;
    --text: #e2e8f0;
    --muted: #64748b;
    --code-bg: #0d1117;
    --good: #10b981;
    --bad: #ef4444;
    --warn: #f59e0b;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    overflow-x: hidden;
    cursor: default;
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 2rem;
    text-align: center;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 20% 40%, rgba(124,58,237,0.15) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(6,182,212,0.12) 0%, transparent 55%),
      radial-gradient(ellipse 40% 30% at 50% 80%, rgba(245,158,11,0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(124,58,237,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124,58,237,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(124,58,237,0.15);
    border: 1px solid rgba(124,58,237,0.3);
    border-radius: 100px;
    padding: 0.4rem 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #a78bfa;
    margin-bottom: 2rem;
    animation: fadeDown 0.6s ease both;
  }

  .hero h1 {
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    animation: fadeDown 0.7s ease both 0.1s;
  }

  .hero h1 span.purple { color: #a78bfa; }
  .hero h1 span.cyan { color: #67e8f9; }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--muted);
    margin-top: 1.5rem;
    max-width: 600px;
    line-height: 1.7;
    animation: fadeDown 0.8s ease both 0.2s;
  }

  .hero-quote {
    margin-top: 2.5rem;
    padding: 1.5rem 2rem;
    border-left: 3px solid var(--accent1);
    background: rgba(124,58,237,0.08);
    border-radius: 0 12px 12px 0;
    max-width: 600px;
    text-align: left;
    animation: fadeDown 0.9s ease both 0.3s;
  }

  .hero-quote p {
    font-style: italic;
    font-size: 1.05rem;
    color: #c4b5fd;
    line-height: 1.8;
  }

  .hero-quote cite {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--muted);
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: var(--muted);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    animation: bounce 2s infinite;
  }

  .scroll-hint svg { width: 20px; opacity: 0.5; }

  /* NAV */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10,10,15,0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .nav::-webkit-scrollbar { display: none; }

  .nav-inner {
    display: flex;
    gap: 0;
    min-width: max-content;
    max-width: 1400px;
    margin: 0 auto;
  }

  .nav-btn {
    padding: 1rem 1.2rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
    background: none;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
  }

  .nav-btn:hover, .nav-btn.active {
    color: var(--text);
    border-bottom-color: var(--accent1);
  }

  /* MAIN LAYOUT */
  .main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  /* SECTION */
  .section {
    margin-bottom: 6rem;
    animation: fadeUp 0.5s ease both;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .section-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--muted);
    background: var(--card);
    border: 1px solid var(--border);
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    white-space: nowrap;
  }

  .section-title {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .accent-bar {
    height: 3px;
    border-radius: 2px;
    flex: 1;
  }

  /* CARDS GRID */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: all 0.25s;
  }

  .card:hover {
    transform: translateY(-3px);
    border-color: rgba(124,58,237,0.3);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    border-radius: 16px 16px 0 0;
  }

  .card.purple::before { background: var(--accent1); }
  .card.cyan::before { background: var(--accent2); }
  .card.amber::before { background: var(--accent3); }
  .card.green::before { background: var(--accent4); }
  .card.red::before { background: var(--accent5); }
  .card.pink::before { background: var(--accent6); }

  .card-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card-title .rule-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    background: rgba(124,58,237,0.2);
    color: #a78bfa;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
  }

  .card-body {
    font-size: 0.88rem;
    line-height: 1.7;
    color: #94a3b8;
  }

  .card-body strong { color: var(--text); }

  /* CODE COMPARE */
  .compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  @media (max-width: 700px) {
    .compare { grid-template-columns: 1fr; }
  }

  .compare-box {
    background: var(--code-bg);
    border-radius: 12px;
    overflow: hidden;
  }

  .compare-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .compare-label.bad { background: rgba(239,68,68,0.15); color: #fca5a5; }
  .compare-label.good { background: rgba(16,185,129,0.15); color: #6ee7b7; }

  .compare-label::before {
    content: '';
    width: 8px; height: 8px;
    border-radius: 50%;
  }

  .compare-label.bad::before { background: #ef4444; }
  .compare-label.good::before { background: #10b981; }

  pre {
    padding: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    line-height: 1.6;
    color: #c0caf5;
    overflow-x: auto;
    white-space: pre-wrap;
  }

  /* BIG RULE CARD */
  .big-rule {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2rem;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .big-rule-num {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-family: 'Space Mono', monospace;
    font-size: 4rem;
    font-weight: 700;
    color: rgba(255,255,255,0.03);
    line-height: 1;
    pointer-events: none;
  }

  .big-rule-title {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tag {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 400;
  }

  .tag.purple { background: rgba(124,58,237,0.2); color: #a78bfa; border: 1px solid rgba(124,58,237,0.3); }
  .tag.cyan { background: rgba(6,182,212,0.2); color: #67e8f9; border: 1px solid rgba(6,182,212,0.3); }
  .tag.amber { background: rgba(245,158,11,0.2); color: #fcd34d; border: 1px solid rgba(245,158,11,0.3); }
  .tag.green { background: rgba(16,185,129,0.2); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.3); }
  .tag.red { background: rgba(239,68,68,0.2); color: #fca5a5; border: 1px solid rgba(239,68,68,0.3); }

  .big-rule p {
    font-size: 0.9rem;
    line-height: 1.8;
    color: #94a3b8;
  }

  .big-rule p strong { color: var(--text); }

  /* RULES LIST */
  .rules-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .rule-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem 1.25rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: border-color 0.2s;
  }

  .rule-item:hover { border-color: rgba(124,58,237,0.3); }

  .rule-bullet {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .rule-item p {
    font-size: 0.88rem;
    line-height: 1.7;
    color: #94a3b8;
  }

  .rule-item p strong { color: var(--text); }

  /* HIGHLIGHT BOX */
  .highlight-box {
    border-radius: 14px;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }

  .highlight-box.purple { background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.25); }
  .highlight-box.cyan { background: rgba(6,182,212,0.08); border: 1px solid rgba(6,182,212,0.2); }
  .highlight-box.amber { background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2); }
  .highlight-box.green { background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2); }
  .highlight-box.red { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); }

  .highlight-box .hb-title {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-family: 'Space Mono', monospace;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }

  .highlight-box.purple .hb-title { color: #a78bfa; }
  .highlight-box.cyan .hb-title { color: #67e8f9; }
  .highlight-box.amber .hb-title { color: #fcd34d; }
  .highlight-box.green .hb-title { color: #6ee7b7; }
  .highlight-box.red .hb-title { color: #fca5a5; }

  .highlight-box p, .highlight-box li {
    font-size: 0.88rem;
    line-height: 1.7;
    color: #94a3b8;
  }

  .highlight-box ul { padding-left: 1.2rem; }
  .highlight-box p strong, .highlight-box li strong { color: var(--text); }

  /* COMPARISON TABLE */
  .comp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    margin: 1.5rem 0;
  }

  .comp-table th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--card);
    border-bottom: 2px solid var(--border);
  }

  .comp-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    color: #94a3b8;
    line-height: 1.6;
  }

  .comp-table td strong { color: var(--text); }
  .comp-table tr:hover td { background: rgba(124,58,237,0.04); }

  /* FLASHCARD QUIZ */
  .quiz-section {
    margin-top: 3rem;
  }

  .quiz-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .flashcard {
    height: 160px;
    perspective: 1000px;
    cursor: pointer;
  }

  .flashcard-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.5s;
    transform-style: preserve-3d;
  }

  .flashcard.flipped .flashcard-inner {
    transform: rotateY(180deg);
  }

  .flashcard-front, .flashcard-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    border-radius: 14px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .flashcard-front {
    background: var(--card);
    border: 1px solid var(--border);
  }

  .flashcard-back {
    background: rgba(124,58,237,0.12);
    border: 1px solid rgba(124,58,237,0.3);
    transform: rotateY(180deg);
  }

  .flashcard-front .fc-q {
    font-size: 0.7rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: 'Space Mono', monospace;
    margin-bottom: 0.5rem;
  }

  .flashcard-front .fc-text {
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.5;
  }

  .flashcard-front .fc-hint {
    font-size: 0.7rem;
    color: var(--muted);
    margin-top: auto;
    font-family: 'JetBrains Mono', monospace;
  }

  .flashcard-back .fc-a {
    font-size: 0.7rem;
    color: #a78bfa;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: 'Space Mono', monospace;
    margin-bottom: 0.5rem;
  }

  .flashcard-back .fc-text {
    font-size: 0.88rem;
    line-height: 1.5;
    color: #c4b5fd;
  }

  /* CHEAT SHEET GRID */
  .cheat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 900px) {
    .cheat-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .cheat-grid { grid-template-columns: 1fr; }
  }

  .cheat-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem;
  }

  .cheat-item .ci-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.4rem;
  }

  .cheat-item .ci-value {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text);
  }

  .cheat-item .ci-desc {
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 0.3rem;
    line-height: 1.5;
  }

  /* MEMORY TRICK */
  .memory-box {
    background: linear-gradient(135deg, rgba(245,158,11,0.1), rgba(239,68,68,0.08));
    border: 1px solid rgba(245,158,11,0.25);
    border-radius: 14px;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }

  .memory-box .mb-title {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #fcd34d;
    margin-bottom: 0.75rem;
  }

  .memory-box .mb-trick {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fbbf24;
    letter-spacing: 0.05em;
  }

  .memory-box .mb-expand {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: #94a3b8;
    line-height: 1.7;
  }

  /* PROGRESS BAR */
  .progress-bar {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    margin: 0.5rem 0;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--accent1), var(--accent2));
  }

  /* DIVIDER */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
    margin: 3rem 0;
  }

  /* ANIMATIONS */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* FOOTER */
  .footer {
    text-align: center;
    padding: 3rem 2rem;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.8rem;
    font-family: 'Space Mono', monospace;
  }

  /* Inline code */
  code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82em;
    background: rgba(124,58,237,0.15);
    color: #c4b5fd;
    padding: 0.1em 0.3em;
    border-radius: 4px;
  }

  /* WIDE CARD */
  .wide-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 1.5rem;
  }

  .wide-card .wc-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* PILL */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .pill.good { background: rgba(16,185,129,0.15); color: #6ee7b7; }
  .pill.bad { background: rgba(239,68,68,0.15); color: #fca5a5; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--accent1); }

  /* MOBILE */
  @media (max-width: 600px) {
    .hero h1 { font-size: 3rem; }
    .main { padding: 2rem 1rem; }
    .cards-grid { grid-template-columns: 1fr; }
  }

  .law-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }
  @media(max-width:700px){ .law-grid { grid-template-columns:1fr; } }

  .law-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
  }

  .law-box h4 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .law-box ul {
    padding-left: 1.2rem;
    font-size: 0.85rem;
    color: #94a3b8;
    line-height: 1.8;
  }

  .law-box ul li strong { color: var(--text); }

  .three-col {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 1rem;
    margin-top:1rem;
  }
  @media(max-width:800px){ .three-col{ grid-template-columns:1fr; } }

</style>
</head>
<body>

